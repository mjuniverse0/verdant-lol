<mah:MetroWindow x:Class="MA_FH5Trainer.Views.Windows.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:local="clr-namespace:MA_FH5Trainer.Views.Windows"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:ip="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance local:MainWindow,IsDesignTimeCreatable=True}"
                 Title="{Binding ViewModel.ApplicationTitle, Mode=OneWay}"
                 Icon="../../Resources/Square150x150Logo.scale-200.png"
                 MinHeight="880"
                 MinWidth="1040"
                 MaxHeight="880"
                 MaxWidth="1040"
                 ShowTitleBar="False"
                 ShowCloseButton="False"
                 ShowMinButton="False"
                 ShowMaxRestoreButton="False"
                 BorderThickness="0"
                 AllowsTransparency="True"
                 Background="Transparent"
                 WindowStyle="None"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterScreen"
                 Closing="MainWindow_OnClosing"
                 MouseDown="MainWindow_OnMouseDown">

    <!-- Verdant External: cards, gold outline, CTA = white (matches verdant.lol) -->
    <Border CornerRadius="{Binding ViewModel.WindowCornerRadius}"
            BorderBrush="{Binding Theming.CardLineBrush}"
            BorderThickness="1"
            Padding="0">
        <Border CornerRadius="{Binding ViewModel.WindowCornerRadius}"
                Background="{Binding Theming.MainColour}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="72" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Top: status + user + window (ref. 2: brand i sidefeltet) -->
                <Border Grid.Row="0"
                        Background="{Binding Theming.DarkColour}"
                        BorderBrush="{Binding Theming.CardLineBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="{Binding ViewModel.TopBarCornerRadius}"
                        Padding="12,8,10,8">
                    <Grid>
                        <StackPanel
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">
                            <Border Background="{Binding Theming.ExpanderHeaderBrush}"
                                    BorderBrush="{Binding Theming.CardLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10,4,12,4"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{Binding ViewModel.ExternalStatusDotBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ViewModel.ExternalStatusText}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="White" />
                                </StackPanel>
                            </Border>
                            <Border Background="{Binding Theming.ExpanderHeaderBrush}"
                                    BorderBrush="{Binding Theming.CardLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,4,10,4"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="USER: VERDANT  ▾"
                                           FontSize="10"
                                           Foreground="{Binding Theming.TextMuted}" />
                            </Border>
                            <Button Tag="1"
                                    Focusable="False"
                                    BorderThickness="0"
                                    Foreground="White"
                                    Background="{Binding Theming.ExpanderHeaderBrush, Mode=OneWay}"
                                    Width="30"
                                    Height="28"
                                    mah:ControlsHelper.CornerRadius="6"
                                    Content="-"
                                    FontSize="12"
                                    Padding="0"
                                    AutomationProperties.AutomationId="Minimize"
                                    AutomationProperties.Name="Minimize"
                                    Click="WindowStateAction_OnClick" />
                            <Button Tag="2"
                                    Focusable="False"
                                    Margin="8,0,0,0"
                                    BorderThickness="0"
                                    Foreground="White"
                                    Background="{Binding Theming.ExpanderHeaderBrush, Mode=OneWay}"
                                    Width="30"
                                    Height="28"
                                    mah:ControlsHelper.CornerRadius="6"
                                    Content="✕"
                                    FontSize="12"
                                    Padding="0"
                                    AutomationProperties.AutomationId="Close"
                                    AutomationProperties.Name="Close"
                                    Click="WindowStateAction_OnClick" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Body -->
                <Grid Grid.Row="1" Margin="10,10,10,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="256" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PanningMode="VerticalOnly">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="36" Height="36" CornerRadius="9" ClipToBounds="True" Background="{Binding Theming.DarkerColour}">
                                    <Image Stretch="Uniform" Source="pack://application:,,,/Resources/Square150x150Logo.scale-200.png" />
                                </Border>
                                <TextBlock Text="VERDANT MOD MENU"
                                           VerticalAlignment="Center"
                                           FontSize="10.5"
                                           FontWeight="Bold"
                                           TextWrapping="NoWrap"
                                           Foreground="White"
                                           Margin="10,0,0,0" />
                            </StackPanel>
                            <!-- Session -->
                            <Border Background="{Binding Theming.CardSurfaceBrush}"
                                    BorderBrush="{Binding Theming.CardLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="GAME INFO"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="{Binding Theming.SectionHeaderForeground}"
                                               Opacity="0.85" />
                                    <TextBlock Text="Session"
                                               FontSize="10"
                                               Foreground="{Binding Theming.TextMuted}"
                                               Margin="0,0,0,8" />
                                    <StackPanel>
                                        <TextBlock Text="Game" FontSize="10" Foreground="{Binding Theming.TextMuted}" />
                                        <TextBlock Text="{Binding ViewModel.ProcessNameText}" FontSize="12.5" Foreground="White" Margin="0,2,0,6" />
                                        <TextBlock Text="Process ID" FontSize="10" Foreground="{Binding Theming.TextMuted}" />
                                        <TextBlock Text="{Binding ViewModel.ProcessIdText}" FontSize="12.5" Foreground="White" Margin="0,2,0,6" />
                                        <TextBlock Text="Platform" FontSize="10" Foreground="{Binding Theming.TextMuted}" />
                                        <TextBlock Text="{Binding ViewModel.PlatformText}" FontSize="12.5" Foreground="White" Margin="0,2,0,6" />
                                        <TextBlock Text="Version" FontSize="10" Foreground="{Binding Theming.TextMuted}" />
                                        <TextBlock Text="{Binding ViewModel.VersionText}" FontSize="12.5" Foreground="White" Margin="0,2,0,6" />
                                        <TextBlock Text="Trainer" FontSize="10" Foreground="{Binding Theming.TextMuted}" />
                                        <TextBlock Text="{Binding ViewModel.TrainerVersion}" FontSize="12.5" Foreground="White" Margin="0,2,0,6" />
                                        <TextBlock Text="Status" FontSize="10" Foreground="{Binding Theming.TextMuted}" />
                                        <TextBlock Text="{Binding ViewModel.AttachedText}"
                                                   FontSize="12.5"
                                                   Foreground="{Binding ViewModel.AttachedBrush}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Hotkeys -->
                            <Border Background="{Binding Theming.CardSurfaceBrush}"
                                    BorderBrush="{Binding Theming.CardLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="HOTKEYS"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="{Binding Theming.SectionHeaderForeground}"
                                               Opacity="0.85" />
                                    <TextBlock Text="Cheat and binding"
                                               FontSize="10"
                                               Foreground="{Binding Theming.TextMuted}"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="CHEAT" FontSize="10" FontWeight="Bold" Foreground="{Binding Theming.TextMuted}" />
                                    <ComboBox SelectedIndex="0"
                                              BorderThickness="0"
                                              Margin="0,4,0,0"
                                              ItemsSource="{Binding ViewModel.Hotkeys}"
                                              SelectedItem="{Binding ViewModel.SelectedHotkey, Mode=TwoWay}"
                                              DisplayMemberPath="Name"
                                              SelectionChanged="ComboBox_SelectionChanged"
                                              IsEnabled="{Binding ViewModel.HotkeysEnabled, Mode=OneWay}"
                                              Background="{Binding Theming.DarkerColour, Mode=OneWay}"
                                              mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}" />
                                    <TextBlock Text="Hotkey"
                                               FontSize="10"
                                               Foreground="{Binding Theming.TextMuted}"
                                               Margin="0,8,0,0" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                CornerRadius="{StaticResource ControlCornerRadius}"
                                                Padding="2"
                                                Margin="0,4,6,0"
                                                HorizontalAlignment="Stretch"
                                                Background="{Binding Theming.DarkerColour, Mode=OneWay}">
                                            <mah:HotKeyBox x:Name="HotKeyBox"
                                                           BorderThickness="0"
                                                           mah:TextBoxHelper.Watermark="None"
                                                           HorizontalAlignment="Stretch"
                                                           HotKey="{Binding ViewModel.SelectedHotkey.Hotkey, Mode=OneWay}"
                                                           IsEnabled="{Binding ViewModel.HotkeysEnabled, Mode=OneWay}"
                                                           Background="{Binding Theming.DarkerColour, Mode=OneWay}"
                                                           mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}" />
                                        </Border>
                                        <Button Grid.Column="1"
                                                Content="SET"
                                                Margin="0,4,0,0"
                                                x:Name="set"
                                                DataContext="{Binding ViewModel.SelectedHotkey}"
                                                Click="ButtonBase_OnClick"
                                                mah:ControlsHelper.FocusBorderThickness="0"
                                                mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                                                Background="{Binding Theming.ExpanderHeaderBrush}"
                                                Foreground="White"
                                                BorderBrush="{Binding Theming.CardLineBrush}"
                                                MinWidth="44" />
                                    </Grid>
                                    <Button Content="Save all hotkeys"
                                            Margin="0,12,0,0"
                                            Click="Button_Click"
                                            FontWeight="SemiBold"
                                            mah:ControlsHelper.FocusBorderThickness="0"
                                            mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                                            Background="{Binding Theming.CtaButtonBackground}"
                                            Foreground="{Binding Theming.CtaButtonForeground}"
                                            BorderBrush="{Binding Theming.CardLineBrush}" />
                                </StackPanel>
                            </Border>

                            <!-- Links -->
                            <Border Background="{Binding Theming.CardSurfaceBrush}"
                                    BorderBrush="{Binding Theming.CardLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="12"
                                    Margin="0,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="QUICK LINKS"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="{Binding Theming.SectionHeaderForeground}"
                                               Opacity="0.85" />
                                    <TextBlock Text="Store and help"
                                               FontSize="10"
                                               Foreground="{Binding Theming.TextMuted}"
                                               Margin="0,0,0,8" />
                                    <Button Command="{Binding ViewModel.OpenURLCommand}" CommandParameter="https://verdant.lol/products.html"
                                            FontWeight="SemiBold" HorizontalContentAlignment="Left" Padding="10,8"
                                            mah:ControlsHelper.FocusBorderThickness="0" mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                                            Background="{Binding Theming.CtaButtonBackground}" Foreground="{Binding Theming.CtaButtonForeground}"
                                            BorderBrush="{Binding Theming.CardLineBrush}">
                                        <StackPanel Orientation="Horizontal">
                                            <ip:PackIconMaterial Width="18" Height="18" VerticalAlignment="Center" Foreground="{Binding Theming.CtaButtonForeground}" Kind="CartOutline" />
                                            <TextBlock Text="Verdant store" VerticalAlignment="Center" Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                    <Button Margin="0,8,0,0" Command="{Binding ViewModel.CheckUpdates_CommandCommand}" HorizontalContentAlignment="Left" Padding="10,8"
                                            mah:ControlsHelper.FocusBorderThickness="0" mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                                            Background="{Binding Theming.ExpanderHeaderBrush}" Foreground="White" BorderBrush="{Binding Theming.CardLineBrush}">
                                        <StackPanel Orientation="Horizontal">
                                            <ip:PackIconMaterial Width="18" Height="18" VerticalAlignment="Center" Foreground="White" Kind="Sync" />
                                            <TextBlock Text="Check for updates" VerticalAlignment="Center" Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                    <Button Margin="0,8,0,0" Command="{Binding ViewModel.OpenURLCommand}" CommandParameter="https://gist.github.com/szaaamerik/32beaf577c863161a35618a20eac2463"
                                            HorizontalContentAlignment="Left" Padding="10,8" mah:ControlsHelper.FocusBorderThickness="0" mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                                            Background="{Binding Theming.ExpanderHeaderBrush}" Foreground="White" BorderBrush="{Binding Theming.CardLineBrush}">
                                        <StackPanel Orientation="Horizontal">
                                            <ip:PackIconMaterial Width="18" Height="18" Foreground="White" Kind="EmoticonHappyOutline" />
                                            <TextBlock Text="FH5 emote IDs" VerticalAlignment="Center" Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                    <Button Margin="0,8,0,0" Command="{Binding ViewModel.OpenURLCommand}" CommandParameter="https://gist.github.com/szaaamerik/c822c4544e789085c80316406daa7540"
                                            HorizontalContentAlignment="Left" Padding="10,8" mah:ControlsHelper.FocusBorderThickness="0" mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                                            Background="{Binding Theming.ExpanderHeaderBrush}" Foreground="White" BorderBrush="{Binding Theming.CardLineBrush}">
                                        <StackPanel Orientation="Horizontal">
                                            <ip:PackIconMaterial Width="18" Height="18" Foreground="White" Kind="FormatPaint" />
                                            <TextBlock Text="Glowing paint guide" VerticalAlignment="Center" Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                    <Button Margin="0,8,0,0" Command="{Binding ViewModel.OpenURLCommand}" CommandParameter="https://github.com/szaaamerik/MA_FH5Trainer"
                                            HorizontalContentAlignment="Left" Padding="10,8" mah:ControlsHelper.FocusBorderThickness="0" mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                                            Background="{Binding Theming.ExpanderHeaderBrush}" Foreground="White" BorderBrush="{Binding Theming.CardLineBrush}">
                                        <StackPanel Orientation="Horizontal">
                                            <ip:PackIconMaterial Width="18" Height="18" Foreground="White" Kind="SourceBranch" />
                                            <TextBlock Text="Upstream - GitHub" VerticalAlignment="Center" Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                    <Button Margin="0,8,0,0" Command="{Binding ViewModel.OpenURLCommand}" CommandParameter="https://discord.gg/rHzev9brJ3"
                                            HorizontalContentAlignment="Left" Padding="10,8" mah:ControlsHelper.FocusBorderThickness="0" mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                                            Background="{Binding Theming.ExpanderHeaderBrush}" Foreground="White" BorderBrush="{Binding Theming.CardLineBrush}">
                                        <StackPanel Orientation="Horizontal">
                                            <ip:PackIconMaterial Width="18" Height="18" Foreground="White" Kind="MessageTextOutline" />
                                            <TextBlock Text="Community - Discord" VerticalAlignment="Center" Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Center">
                                <Border Width="22" Height="22" CornerRadius="5" ClipToBounds="True" Background="{Binding Theming.DarkerColour}">
                                    <Image Stretch="Uniform" Source="pack://application:,,,/Resources/Square150x150Logo.scale-200.png" />
                                </Border>
                                <TextBlock Text="{Binding ViewModel.TrainerVersion}" FontSize="10" Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Column="2"
                            Background="{Binding Theming.CardSurfaceBrush}"
                            BorderBrush="{Binding Theming.CardLineBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="4"
                            SnapsToDevicePixels="True">
                        <Frame Content="{Binding ViewModel.ExpandersView, Mode=OneWay}"
                               NavigationUIVisibility="Hidden"
                               JournalOwnership="OwnsJournal" />
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Border>
</mah:MetroWindow>
