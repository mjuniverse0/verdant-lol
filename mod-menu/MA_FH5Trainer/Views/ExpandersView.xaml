<Page x:Class="MA_FH5Trainer.Views.ExpandersView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:MA_FH5Trainer.Views"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      xmlns:models="clr-namespace:MA_FH5Trainer.Models"
      xmlns:converters="clr-namespace:MA_FH5Trainer.Converters"
      xmlns:ip="http://metro.mahapps.com/winfx/xaml/iconpacks"
      mc:Ignorable="d"
      Title="ExpandersView"
      d:DataContext="{d:DesignInstance local:ExpandersView,IsDesignTimeCreatable=True}"
      d:DesignHeight="700"
      d:DesignWidth="640">
    <Page.Resources>
        <converters:ModPageTypeToInstanceConverter x:Key="ModPageTypeToInstanceConverter" />
        <converters:IconKindStringToMaterialKindConverter x:Key="IconKindStringToMaterialKindConverter" />
    </Page.Resources>

    <Grid Background="{Binding Theming.MainColour}">
        <!-- Dashboard -->
        <ScrollViewer x:Name="DashboardRoot"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding ViewModel.IsModDashboardVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ScrollViewer.Resources>
                <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
                    <Setter Property="OverridesDefaultStyle" Value="true" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type Thumb}">
                                <Border Background="{Binding Theming.LightColour}"
                                        CornerRadius="{StaticResource ControlCornerRadius}" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="ScrollBar">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Border Background="{Binding Theming.DarkerColour}" Width="10" CornerRadius="{StaticResource ControlCornerRadius}">
                                        <Track IsDirectionReversed="True">
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource ScrollBarThumb}" />
                                            </Track.Thumb>
                                        </Track>
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ScrollViewer.Resources>

            <StackPanel Margin="8,8,12,16">
                <!-- Hero: V logo -->
                <Border Background="{Binding Theming.CardSurfaceBrush}"
                        BorderBrush="{Binding Theming.CardLineBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14"
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="80" Height="80" CornerRadius="16" ClipToBounds="True" Background="{Binding Theming.DarkerColour}">
                            <Image Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Source="pack://application:,,,/Resources/Square150x150Logo.scale-200.png" />
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Verdant Mod Menu"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="White" />
                            <TextBlock Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       FontSize="11.5"
                                       LineHeight="16"
                                       Foreground="{Binding Theming.TextMuted}">
                                <Run Text="UI aligned with Verdant External and Remap Studio. Forza Horizon 5 controls &amp; memory features unchanged. Use in line with your license and game ToS." />
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Text="MAIN FEATURES"
                           FontSize="9"
                           FontWeight="Bold"
                           Foreground="{Binding Theming.TextMuted}"
                           Margin="4,0,0,8" />
                <ItemsControl ItemsSource="{Binding ViewModel.MainModFeatures}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ModFeatureItem}">
                            <Button Command="{Binding DataContext.ViewModel.OpenModPageCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding PageType}"
                                    Foreground="White"
                                    Padding="10,8"
                                    MinHeight="72"
                                    Margin="4"
                                    HorizontalContentAlignment="Stretch"
                                    mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                                    mah:ControlsHelper.FocusBorderThickness="0"
                                    Background="{Binding DataContext.Theming.DarkerColour, RelativeSource={RelativeSource AncestorType=Page}}"
                                    BorderBrush="{Binding DataContext.Theming.CardLineBrush, RelativeSource={RelativeSource AncestorType=Page}}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ip:PackIconMaterial Grid.Column="0"
                                                        Width="22"
                                                        Height="22"
                                                        VerticalAlignment="Center"
                                                        Foreground="White"
                                                        Kind="{Binding IconKind, Converter={StaticResource IconKindStringToMaterialKindConverter}}" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="11.5" />
                                        <TextBlock Text="{Binding Subtitle}"
                                                   FontSize="10"
                                                   Margin="0,2,0,0"
                                                   Foreground="#c8c8c8" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="›"
                                               FontSize="18"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"
                                               Foreground="#b8b8b8" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="TUNING"
                           FontSize="9"
                           FontWeight="Bold"
                           Foreground="{Binding Theming.TextMuted}"
                           Margin="4,20,0,8" />
                <ItemsControl ItemsSource="{Binding ViewModel.TuningModFeatures}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ModFeatureItem}">
                            <Button Command="{Binding DataContext.ViewModel.OpenModPageCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding PageType}"
                                    Foreground="White"
                                    Padding="10,8"
                                    MinHeight="72"
                                    Margin="4"
                                    HorizontalContentAlignment="Stretch"
                                    mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                                    mah:ControlsHelper.FocusBorderThickness="0"
                                    Background="{Binding DataContext.Theming.DarkerColour, RelativeSource={RelativeSource AncestorType=Page}}"
                                    BorderBrush="{Binding DataContext.Theming.CardLineBrush, RelativeSource={RelativeSource AncestorType=Page}}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ip:PackIconMaterial Grid.Column="0"
                                                        Width="22"
                                                        Height="22"
                                                        VerticalAlignment="Center"
                                                        Foreground="White"
                                                        Kind="{Binding IconKind, Converter={StaticResource IconKindStringToMaterialKindConverter}}" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="11.5" />
                                        <TextBlock Text="{Binding Subtitle}"
                                                   FontSize="10"
                                                   Margin="0,2,0,0"
                                                   Foreground="#c8c8c8" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="›"
                                               FontSize="18"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"
                                               Foreground="#b8b8b8" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Detail -->
        <Grid Visibility="{Binding ViewModel.IsModDetailVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    Background="{Binding Theming.DarkerColour}"
                    BorderBrush="{Binding Theming.CardLineBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="6,4">
                <Button HorizontalAlignment="Left"
                        MinWidth="120"
                        Padding="10,6"
                        Content="←  Main menu"
                        Command="{Binding ViewModel.CloseModPageCommand}"
                        Foreground="White"
                        BorderBrush="{Binding Theming.CardLineBrush}"
                        Background="{Binding Theming.ExpanderHeaderBrush}"
                        mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                        mah:ControlsHelper.FocusBorderThickness="0" />
            </Border>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,4,0,0">
                <Frame x:Name="ModDetailFrame"
                       NavigationUIVisibility="Hidden"
                       JournalOwnership="OwnsJournal"
                       Content="{Binding ViewModel.ModPageType, Converter={StaticResource ModPageTypeToInstanceConverter}}" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
