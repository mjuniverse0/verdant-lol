DISCORD_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here
# Optional overrides (defaults are already set in code)
CLIENT_UPDATE_CHANNEL_ID=
CLIENT_STATUS_CHANNEL_ID=
REQUEST_CONFIG_CHANNEL_ID=
CLAIM_ORDER_CHANNEL_ID=
APPLICATION_PANEL_CHANNEL_ID=
APPLICATION_STATUS_CHANNEL_ID=
SUPPORT_CATEGORY_ID=
STAFF_CATEGORY_ID=
TICKETS_CATEGORY_ID=
ARCHIVE_CATEGORY_ID=
FOUNDER_ROLE_ID=
LOGS_CHANNEL_ID=
CUSTOMER_ROLE_ID=

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ORDERS_TABLE=orders

# Stripe (https://dashboard.stripe.com/apikeys) - Checkout Session for card / wallet
STRIPE_SECRET_KEY=
# Webhook signing secret (https://dashboard.stripe.com/webhooks) - endpoint: /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
# Optional: Payment Method Configuration ID from Dashboard (pmc_…). Lets you enable MB WAY, Link, etc. without hard-coding types. If set, STRIPE_CHECKOUT_PAYMENT_METHOD_TYPES is ignored.
STRIPE_CHECKOUT_PAYMENT_METHOD_CONFIGURATION=
# Optional: comma-separated Checkout payment_method_types, e.g. card,mb_way. MB WAY requires EUR - use data-currency="EUR" on product cards or omit mb_way for USD-only checkouts (server strips mb_way when currency is not eur).
STRIPE_CHECKOUT_PAYMENT_METHOD_TYPES=
# Public site URL (https) for Stripe success/cancel URLs. Required if the app is behind a proxy; otherwise host is inferred.
PUBLIC_APP_URL=
WEB_PORT=8787

# Dashboard: payment alerts bell (optional). Shop operators can issue keys via POST /api/shop/grant-licenses when authorized.
DASHBOARD_ADMIN_SECRET=
# Comma-separated dashboard login emails allowed to call grant API (must match body.operatorEmail). Empty = grant allowed for any bearer of SHOP_GRANT_SECRET / DASHBOARD_ADMIN_SECRET only.
VERDANT_SHOP_OPERATOR_EMAILS=
# Optional separate bearer for grant API; if empty, DASHBOARD_ADMIN_SECRET is accepted for grants too.
SHOP_GRANT_SECRET=
LAUNCHER_LATEST_VERSION=1.0.0
LAUNCHER_API_BASE=https://verdant.lol
# Executor architecture (since the ViGEm runtime was retired):
#   1. The launcher POSTs scripts to ${LAUNCHER_API_BASE}/api/executor/execute
#      (default https://verdant.lol/api/executor) with X-Verdant-HWID,
#      X-Verdant-License and X-Verdant-Author headers.
#   2. server.js proxies /api/executor/{execute,pull,ack,health} to
#      VERDANT_EXECUTOR_UPSTREAM (the per-HWID queue daemon).
#   3. scripts/executor-daemon.js is that daemon (deployed via pm2 as
#      verdant-executor; default 127.0.0.1:6969). Replaces the old stub.
#   4. The local C++ agent (client/executor/verdant_executor.exe) long-polls
#      /api/executor/pull?hwid=X, executes the script via the kernel bridge
#      and POSTs /api/executor/ack with the outcome.
#
# Override the launcher target (e.g. for local-only testing):
# VERDANT_EXECUTOR_URL=http://127.0.0.1:6969
# On the VPS (server.js): point at the per-HWID daemon, e.g.
# VERDANT_EXECUTOR_UPSTREAM=http://127.0.0.1:6969
# Daemon overrides:
# EXECUTOR_DAEMON_PORT=6969
# EXECUTOR_QUEUE_LIMIT=50
# EXECUTOR_JOB_TTL_MS=3600000
# Windows: full path to ViGEmClient.dll if not on default search path
VIGEM_CLIENT_DLL=
# Set to 1 to log [FFI:debug] stick values every 2s in the launcher
VERDANT_FFI_DEBUG=
# Comma-separated foreground .exe basenames (optional). Example: Fortnite + Apex
# VERDANT_FOCUS_EXES=FortniteClient-Win64-Shipping.exe,r5apex.exe

# Cross-experience chat overlay (client/overlay).
# Room id is the shared "secret" between friends - generate one per friend group.
# Default seeded room from migration: 00000000-0000-0000-0000-00000000c1a7
VERDANT_CHAT_ROOM_ID=
# Optional overrides; computed from machine + user name when blank.
VERDANT_CHAT_AUTHOR_ID=
VERDANT_CHAT_AUTHOR_NAME=
